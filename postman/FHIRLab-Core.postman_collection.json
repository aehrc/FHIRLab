			"name": "HAPI FHIR",
			"item": [
				{
					"name": "Server Metadata",
					"item": [
						{
							"name": "Get Server Metadata",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"pm.test(\"Status code is 200\", function () {",
											"    pm.response.to.have.status(200);",
											"});",
											"",
											"pm.test(\"Response is FHIR CapabilityStatement\", function () {",
											"    var jsonData = pm.response.json();",
											"    pm.expect(jsonData.resourceType).to.eql(\"CapabilityStatement\");",
											"});"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "GET",
								"header": [
									{
										"key": "Accept",
										"value": "application/fhir+json"
									}
								],
								"url": {
									"raw": "{{fhir_base}}/metadata",
									"host": [
										"{{fhir_base}}"
									],
									"path": [
										"metadata"
									]
								},
								"description": "Retrieve the server's CapabilityStatement describing supported resources and operations."
							},
							"response": []
						}
					]
				},
