      "value": "",
      "description": "Paste contents of bundles/03-chronic-conditions.json"
    },
    {
      "key": "bundle_04",
      "value": "",
      "description": "Paste contents of bundles/04-allergy-records.json"
    },
    {
      "key": "bundle_05",
      "value": "",
      "description": "Paste contents of bundles/05-immunization-history.json"
    },
    {
      "key": "bundle_06",
      "value": "",
      "description": "Paste contents of bundles/06-lab-results.json"
    },
    {
      "key": "bundle_07",
      "value": "",
      "description": "Paste contents of bundles/07-medication-plan.json"
    },
    {
      "key": "bundle_08",
      "value": "",
      "description": "Paste contents of bundles/08-full-encounter.json"
    }
  ]
