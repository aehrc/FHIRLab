# FHIRLab Core - Environment Configuration
# =========================================
# Copy this file to .env and modify as needed.
# Default values are suitable for learning environments.
#
# Usage: cp .env.example .env

# ==========================================================================
# HAPI FHIR Server Configuration
# ==========================================================================

# Port for HAPI FHIR server (default: 8080)
HAPI_FHIR_PORT=8080

# External URL for HAPI FHIR server (used in resource references)
# Change this if accessing from a different machine
HAPI_FHIR_SERVER_ADDRESS=http://localhost:8080/fhir

# ==========================================================================
# Elasticsearch Configuration (for Snowstorm)
# ==========================================================================

# Elasticsearch port binding (default: localhost only for security)
# Change to 0.0.0.0:9200 to allow external access
ES_PORT=127.0.0.1:9200

# Elasticsearch heap size (default: 2g, recommended: 4g for better performance)
# Minimum: 1g, requires at least 4GB system RAM
ES_HEAP_SIZE=2g

# Elasticsearch memory reservation
ES_MEMORY=2g

# ==========================================================================
# Snowstorm (SNOMED CT) Configuration
# ==========================================================================

# Port for Snowstorm API (default: 8081)
SNOWSTORM_PORT=8081

# Snowstorm JVM heap settings
SNOWSTORM_MIN_HEAP=1g
SNOWSTORM_MAX_HEAP=2g

# ==========================================================================
# SNOMED CT Browser Configuration
# ==========================================================================

# Port for SNOMED CT Browser web interface (default: 8082)
SNOMED_BROWSER_PORT=8082

# ==========================================================================
# SMART on FHIR Configuration (Optional)
# Enable with: docker compose --profile smart up -d
# ==========================================================================

# Port for SMART Launcher (default: 8083)
SMART_LAUNCHER_PORT=8083

# ==========================================================================
# FormLab Configuration (Optional)
# Enable with: docker compose --profile formlab up -d
# Complete SMART-on-FHIR demonstration with forms and sample data
# Reference: https://gitlab.com/australian-e-health-research-centre/form-lab
# ==========================================================================

# Port for FormLab Homepage (default: 8084)
FORMLAB_PORT=8084

# Port for FormLab SMART Launcher UI (default: 8085)
FORMLAB_LAUNCHER_PORT=8085

# Port for FormLab SMART Proxy (default: 8086)
FORMLAB_PROXY_PORT=8086

# Port for FormLab Forms Application (default: 8087)
FORMLAB_FORMS_PORT=8087

# Port for FormLab HAPI FHIR Server (default: 8088)
FORMLAB_FHIR_PORT=8088

# FormLab Database Configuration
FORMLAB_DB_USER=admin
FORMLAB_DB_PASSWORD=admin
FORMLAB_DB_NAME=hapi

# ==========================================================================
# System Requirements
# ==========================================================================
# Minimum: 8GB RAM, 20GB disk space
# Recommended: 16GB RAM, 50GB disk space
#
# If running on a system with limited RAM, reduce heap sizes:
#   ES_HEAP_SIZE=1g
#   SNOWSTORM_MAX_HEAP=1g
